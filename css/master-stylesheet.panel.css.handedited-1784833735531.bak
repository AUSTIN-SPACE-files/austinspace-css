 --blue-050: #e8f5ff;
 --orange-500: #ff7a33;
 --orange-600: #ef631c;
 --orange-700: #cf5311;
 --orange-050: #fff0e6;
 --yellow-400: #ffd23f;

 --candy-pink: #ec4d97;
 --candy-pink-deep: #d23c83;
 --candy-pink-lt: #f26cae;
 --candy-pink-050: #fdeaf3;
 --sunshine: #f4cf3b;
 --tangerine: #f07d2e;
 --bead-blue: #4f7cc9;
 --bead-blue-lt: #7fa3dd;
 --liquorice: #17171a;

 --paper-000: var(--white);
 --paper-050: var(--grey-050);
 --paper-100: var(--grey-100);
 --paper-200: var(--grey-200);

 --surface-canvas: var(--white);
 --surface-inset: var(--grey-050);
 --surface-card: var(--white);
 --surface-card-alt: var(--grey-050);
 --surface-ink: var(--ink-800);
 --surface-cosmos: var(--void-800);

 --text-strong: var(--ink-900);
 --text-body: var(--grey-500);
 --text-muted: var(--grey-400);
 --text-invert: var(--white);
 --text-invert-muted: #a9a9b4;

 --border-subtle: var(--grey-200);
 --border-strong: var(--ink-900);

 --accent: var(--candy-pink);
 --accent-hover: var(--candy-pink-deep);
 --accent-tint: var(--candy-pink-050);
 --accent-dot: var(--bead-blue);
 --accent-lum: var(--candy-pink-lt);

 --accent-secondary: var(--bead-blue);
 --accent-secondary-lum: var(--bead-blue-lt);
 --accent-tertiary: var(--sunshine);

 --btn-primary: var(--ink-900);
 --btn-primary-hover: #26262e;

 --focus-ring: var(--candy-pink);

 --success: var(--teal-600);
 --info: var(--blue-600);
 --warning: var(--yellow-400);
 --danger: var(--magenta-600);

 --link: var(--candy-pink);
 --link-hover: var(--candy-pink-deep);
}

:root {

 --fw-regular: 400;
 --fw-medium: 500;
 --fw-semibold:600;
 --fw-bold: 700;
 --fw-display: 900;

 --fs-display: 76px;
 --fs-h1: 54px;
 --fs-h2: 40px;
 --fs-h3: 28px;
 --fs-h4: 21px;
 --fs-body-lg: 19px;
 --fs-body: 16px;
