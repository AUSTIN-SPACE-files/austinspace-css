 --lh-snug: 1.35;
 --lh-body: 1.6;

 --ls-display: -0.03em;
 --ls-heading: -0.01em;
 --ls-body: 0em;
 --ls-label: 0.16em;
}

:root {
 --space-0: 0;
 --space-1: 4px;
 --space-2: 8px;
