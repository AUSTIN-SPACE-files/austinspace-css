 flex-direction: column;
 gap: 0;
 flex-grow: 1;
}

.as-hub-card__icon {
 display: flex;
}

.as-hub-card__tag {
 font-family: var(--font-mono);
 font-size: 11.5px;
 font-weight: 500;
 letter-spacing: var(--ls-label);
 text-transform: uppercase;
