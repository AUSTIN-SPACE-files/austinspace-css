@media (max-width: 480px) {
.as-faq:has(~ .as-hero--contact-footer){
  margin-bottom: 160px;
}
}

@media (max-width: 480px) {
.as-cs-page-cta:has(~ .as-hero[class*="-footer"]){
  margin-bottom: 160px;
}
}

@media (min-width: 481px) {
.as-allsorts .as-faq:has(~ .as-hero--contact-footer) { padding-bottom: var(--as-clear-wave); }
}

