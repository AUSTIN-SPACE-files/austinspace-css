 margin: 20px 0 9px;
}

.as-hub-card__title {
 font-family: var(--font-display);
 font-size: 1.55rem;
 font-weight: 400;
 line-height: 1.15;
 letter-spacing: -0.01em;
 color: var(--as-black);
 margin: 0 0 12.8px;
}

.as-hub-card__price {
 font-family: var(--font-body);
 font-size: 14px;
 font-weight: 500;
 line-height: 1.50;
 color: var(--as-mid);
