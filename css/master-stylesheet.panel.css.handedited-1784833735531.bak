.as-allsorts .as-cs-solution__grid .as-cs-phase:nth-child(2) .as-cs-phase__number { color: var(--bead-blue-lt); }
.as-allsorts .as-cs-solution__grid .as-cs-phase:nth-child(3) .as-cs-phase__number { color: var(--tangerine); }
.as-allsorts .as-cs-solution__grid .as-cs-phase:nth-child(4) .as-cs-phase__number { color: var(--sunshine); }

.as-allsorts .as-cs-phase__title {
  grid-column: 1;
  grid-row: 2;
  color: #fff;
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 24px;
  line-height: 1.20;
  margin: 8px 0 14px;
}

.as-allsorts .as-cs-phase__list {
  grid-column: 1;
  grid-row: 3;
  align-self: start;
  border-top: 0;
  padding: 0;
  margin: 0;
}
.as-allsorts .as-cs-phase__list li {
  color: #9a9aa2;
  font-size: 14.5px;
  line-height: 1.55;
  padding: 0 0 7px 0;
}

.as-allsorts .as-cs-phase__list li i {
  display: none;
}

.as-allsorts .as-cs-phase__image {
  grid-column: 2;
  grid-row-start: 1;
  grid-row-end: 4;
  position: relative;
  width: 88%;
  aspect-ratio: 16 / 10;
  border: 0;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.75);
  transform: rotate(-3deg);
  align-self: center;
  z-index: 1;
  margin: 0;
}
.as-allsorts .as-cs-phase__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.as-allsorts .as-cs-phase__phone {
  grid-column: 2;
  grid-row-start: 1;
  grid-row-end: 4;
  align-self: end;
  justify-self: end;
  width: 34%;
  aspect-ratio: 9 / 17;
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.75);
  transform: rotate(5deg) translateY(28px);
  margin-right: -6%;
  z-index: 2;
}
.as-allsorts .as-cs-phase__phone img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__number,
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__title,
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__list {
  grid-column: 2;
}
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__image,
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__phone {
  grid-column: 1;
}
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__image {
  transform: rotate(3deg);
  margin-left: auto;
}
.as-allsorts .as-cs-phase:nth-child(even) .as-cs-phase__phone {
  justify-self: start;
  margin-right: 0;
  margin-left: -6%;
  transform: rotate(-5deg) translateY(28px);
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* "View live site" promoted to a button; the shared .as-cs-hero__link rule */
/* already sets align-self: flex-start, but this pins it explicitly for the */
/* button treatment on this page since DDR/AUSTIN_SPACE keep the plain link. */
.as-allsorts .as-cs-terracotta .as-cs-hero__link {
  align-self: flex-start;
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Both hero frames now show the same home page image and merge where they */
/* overlap, so the pair is resized and repositioned for clearer separation */
/* rather than left at the shared 88%/34% arrangement. */
.as-allsorts .as-cs-terracotta .as-cs-hero__media-desktop {
  width: 92%;
}

/* The as-cs-phase pair uses a much heavier shadow (0 14px 40px rgba(0,0,0,.75)) */
/* deliberately, since it sits on ink rather than white; this value sits between */
/* that and the original hero shadow (0 8px 24px rgba(0,0,0,.16)) because the two */
/* hero frames are now near-identical images and need more separation than the */
/* original provided. Desktop frame keeps its original light shadow untouched. */
.as-allsorts .as-cs-terracotta .as-cs-hero__media-phone {
  width: 28%;
  right: -2%;
  bottom: -18px;
  transform: rotate(6deg);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.26);
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Stat bar header, matching the as-creds "By the Numbers" pattern */
.as-allsorts .as-cs-terracotta .as-cs-stats__header {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 56px;
}

/* as-cs-section-headline defaults to --ink-900 for light sections; */
/* override to white here so it is legible on the dark as-cs-stats band */
.as-allsorts .as-cs-terracotta .as-cs-stats__header .as-cs-section-headline {
  color: #fff;
}

/* Deliberately diverges from as-creds__number (Fraunces 800): lighter, */
/* smaller and tighter-tracked for legibility, rhymes with the Fraunces 400 */
/* used on the solution step titles and FAQ questions on this page. */
.as-allsorts .as-cs-terracotta .as-cs-stats__number {
  font-weight: 400;
  font-size: 36px;
  letter-spacing: normal;
}

/* Two-line label: bold block headline + grey supporting sentence, */
/* mirroring as-creds__text / as-creds__text strong exactly */
.as-allsorts .as-cs-terracotta .as-cs-stats__label {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
  letter-spacing: 0.01em;
}

.as-allsorts .as-cs-terracotta .as-cs-stats__label strong {
  display: block;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  font-size: 0.88rem;
  margin-bottom: 0.15rem;
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Solution section: numbered vertical spine, replaces the alternating as-cs-phase rows */
.as-allsorts .as-cs-terracotta .as-cs-solution__spine {
  position: relative;
  padding-left: 96px;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step {
  position: relative;
  padding-bottom: 44px;
}
.as-allsorts .as-cs-terracotta .as-cs-solution__step::before {
  content: '';
  position: absolute;
  left: -34px;
  top: 8px;
  bottom: 44px;
  width: 2px;
  background: rgba(255, 255, 255, 0.20);
}
.as-allsorts .as-cs-terracotta .as-cs-solution__step:last-child {
  padding-bottom: 0;
}
.as-allsorts .as-cs-terracotta .as-cs-solution__step:last-child::before {
  bottom: 0;
}
.as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(even) {
  margin-left: 200px;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__marker {
  position: absolute;
  left: -96px;
  top: -6px;
  width: 56px;
}
.as-allsorts .as-cs-terracotta .as-cs-solution__marker i {
  display: block;
  font-size: 56px;
  text-align: left;
  line-height: 1;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(1) .as-cs-solution__marker i { color: var(--candy-pink-lt); }
.as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(2) .as-cs-solution__marker i { color: var(--bead-blue-lt); }
.as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(3) .as-cs-solution__marker i { color: var(--tangerine); }
.as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(4) .as-cs-solution__marker i { color: var(--sunshine); }

.as-allsorts .as-cs-terracotta .as-cs-solution__step-title {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: 23px;
  line-height: 1.3;
  letter-spacing: normal;
  color: #fff;
  margin: 0 0 10px;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step-lead {
  font-family: var(--font-body);
  font-size: 15.5px;
  line-height: 1.6;
  color: rgb(198, 198, 206);
  margin: 0 0 14px;
  max-width: 760px;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px 28px;
  max-width: 820px;
  margin: 0;
  padding: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step-list li {
  position: relative;
  font-family: var(--font-body);
  font-size: 14.5px;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.5);
  padding-left: 18px;
}
.as-allsorts .as-cs-terracotta .as-cs-solution__step-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  width: 6px;
  height: 2px;
  background: rgba(255, 255, 255, 0.35);
}

.as-allsorts .as-cs-terracotta .as-cs-solution__step-note {
  font-style: italic;
  font-family: var(--font-body);
  font-size: 14.5px;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.5);
  max-width: 820px;
  margin: 14px 0 0;
}

@media (max-width: 767px) {
  .as-allsorts .as-cs-terracotta .as-cs-solution__spine {
    padding-left: 52px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-solution__step::before {
    left: -37px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-solution__step:nth-child(even) {
    margin-left: 0;
  }
  .as-allsorts .as-cs-terracotta .as-cs-solution__marker {
    left: -52px;
    width: 32px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-solution__marker i {
    font-size: 32px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-solution__step-list {
    grid-template-columns: 1fr;
  }
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Results section: own white band, sits between as-cs-solution and as-cs-beforeafter */
.as-allsorts .as-cs-terracotta .as-cs-results {
  background: var(--as-white);
  padding: var(--as-space-section) var(--as-space-section-side);
}

.as-allsorts .as-cs-terracotta .as-cs-results__eyebrow {
  font-family: var(--font-mono);
  font-size: 12.5px;
  font-weight: 500;
  letter-spacing: var(--ls-label);
  text-transform: uppercase;
  color: var(--bead-blue);
  margin: 0 0 12px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 32px;
  line-height: 1.15;
  color: var(--ink-900);
  margin: 0 0 18px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__intro {
  font-family: var(--font-body);
  font-size: 16.5px;
  line-height: 1.6;
  color: var(--grey-500);
  max-width: 640px;
  margin: 0 0 40px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin: 0 0 16px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat {
  background: var(--white);
  border: var(--bw) solid var(--ink-900);
  border-radius: var(--radius-lg);
  box-shadow: var(--pop-md);
  overflow: hidden;
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: box-shadow var(--transition), transform var(--transition);
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat .as-topper {
  margin: -2.2rem -2.2rem 16px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat-icon {
  display: flex;
  justify-content: flex-start;
  align-self: flex-start;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat-icon i {
  font-size: 52px;
  line-height: 1;
  --fa-secondary-opacity: 1;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat:nth-child(1) .as-cs-results__stat-icon i {
  --fa-primary-color: #ec4d97;
  --fa-secondary-color: #f6aed0;
  color: #ec4d97;
}
.as-allsorts .as-cs-terracotta .as-cs-results__stat:nth-child(2) .as-cs-results__stat-icon i {
  --fa-primary-color: #4f7cc9;
  --fa-secondary-color: #afc4e6;
  color: #4f7cc9;
}
.as-allsorts .as-cs-terracotta .as-cs-results__stat:nth-child(3) .as-cs-results__stat-icon i {
  --fa-primary-color: #f07d2e;
  --fa-secondary-color: #f8c4a0;
  color: #f07d2e;
}
.as-allsorts .as-cs-terracotta .as-cs-results__stat:nth-child(4) .as-cs-results__stat-icon i {
  --fa-primary-color: #d69d1c;
  --fa-secondary-color: #fae9a6;
  color: #d69d1c;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat-number {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 34px;
  letter-spacing: -0.01em;
  color: var(--ink-900);
  margin: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat-label {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 15px;
  color: var(--ink-900);
  margin: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-results__stat-desc {
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 15px;
  line-height: 1.55;
  color: var(--grey-500);
  margin: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-results__source {
  font-family: var(--font-mono);
  font-size: 12px;
  font-style: italic;
  color: var(--grey-500);
  margin: 0 0 48px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__prose h4 {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 19px;
  color: var(--ink-900);
  margin: 0 0 12px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__prose p {
  font-family: var(--font-body);
  font-size: 14.5px;
  line-height: 1.6;
  color: var(--grey-500);
  margin: 0 0 14px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__prose p:last-child {
  margin-bottom: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-results__prose + .as-cs-results__prose {
  margin-top: 32px;
}

.as-allsorts .as-cs-terracotta .as-cs-results__prose p.as-cs-results__source {
  font-family: var(--font-mono);
  font-size: 12px;
  font-style: italic;
  color: var(--grey-500);
  margin: 0;
}

@media (max-width: 767px) {
  .as-allsorts .as-cs-terracotta .as-cs-results__stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Selected-pages tabbed gallery, sits between as-cs-results and as-cs-testimonial */
.as-allsorts .as-cs-terracotta .as-cs-gallery {
  background: var(--as-white);
  padding: var(--as-space-section) var(--as-space-section-side);
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__intro {
  font-family: var(--font-body);
  font-size: 17px;
  line-height: 1.6;
  color: var(--grey-500);
  max-width: 640px;
  margin: 0 0 48px;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__intro a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  border-bottom: 1px solid var(--as-border);
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__tab {
  position: relative;
  font-family: var(--font-mono);
  font-size: 12.5px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--grey-500);
  background: none;
  border: none;
  padding: 14px 22px;
  cursor: pointer;
  transition: color 0.2s ease;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__tab:hover {
  color: var(--ink-900);
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__tab[aria-selected="true"] {
  color: var(--ink-900);
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__tab[aria-selected="true"]::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  height: 2px;
  background: var(--candy-pink);
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__stage {
  margin-top: 32px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--as-border);
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.10);
  background: #f4f4f4;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__panel {
  display: none;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__panel:not([hidden]) {
  display: block;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__img {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  object-position: top center;
}

.as-allsorts .as-cs-terracotta .as-cs-gallery__cap {
  font-family: var(--font-mono);
  font-size: 12.5px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--grey-500);
  margin-top: 18px;
}

@media (max-width: 640px) {
  .as-allsorts .as-cs-terracotta .as-cs-gallery {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  .as-allsorts .as-cs-terracotta .as-cs-gallery .as-cs-section-headline {
    font-size: 32px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-gallery__tab {
    padding: 10px 12px;
    letter-spacing: 1px;
  }
}

/* Terracotta case study only, scoped to .as-cs-terracotta wrapper */
/* Testimonial quote in DM Serif Display instead of the sitewide Fraunces default */
/* B1 editorial redesign: header + two-column grid, replaces the centered card */
.as-allsorts .as-cs-terracotta .as-cs-testimonial__inner {
  max-width: 1160px;
  display: block;
  text-align: left;
  gap: 0;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__header {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 56px;
}

/* as-cs-section-headline defaults to --ink-900 for light sections; */
/* override to white here so it is legible on the dark testimonial band */
.as-allsorts .as-cs-terracotta .as-cs-testimonial__header .as-cs-section-headline {
  color: #fff;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__grid {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 72px;
  align-items: start;
}

/* Opening Press quote mark: block, sits above the quote */
.as-allsorts .as-cs-terracotta .as-cs-testimonial__mark-open {
  display: block;
  font-size: 52px;
  line-height: 0.6;
  color: var(--candy-pink-lt);
  margin: 0 0 18px;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__quote {
  font-family: "DM Serif Display", Georgia, "Times New Roman", serif;
  font-style: italic;
  font-weight: 400;
  font-size: 24px;
  line-height: 1.5;
  color: #fff;
  max-width: none;
  margin: 0;
  text-align: left;
}

/* Closing Press quote mark: fa-quote-right is not in the Slab Press pack */
/* (tofu), so this reuses fa-quote-left mirrored horizontally instead. */
/* scaleX and translateY act on independent axes so they commute here; */
/* order does not change the result. translateY(8px) baseline nudge is */
/* a starting estimate only, still needs live visual check. */
.as-allsorts .as-cs-terracotta .as-cs-testimonial__mark-close {
  display: inline-block;
  font-size: 32px;
  color: var(--bead-blue-lt);
  margin-left: 8px;
  transform: scaleX(-1) translateY(8px);
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__side {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
  text-align: left;
  border-left: 2px solid var(--candy-pink);
  padding-left: 26px;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__side .as-cs-testimonial__name {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__side .as-cs-testimonial__role {
  font-family: var(--font-mono);
  font-size: 12.5px;
  font-weight: 400;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--grey-500);
  line-height: 1.5;
}

.as-allsorts .as-cs-terracotta .as-cs-testimonial__side .as-casestudy__quote-source {
  margin-left: 0;
  margin-top: 10px;
}

@media (max-width: 767px) {
  .as-allsorts .as-cs-terracotta .as-cs-testimonial__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .as-allsorts .as-cs-terracotta .as-cs-testimonial__side {
    border-left: 0;
    padding-left: 0;
    border-top: 2px solid var(--candy-pink);
    padding-top: 20px;
  }
}

.as-allsorts .as-cs-beforeafter__img {
  border: var(--bw) solid var(--ink-900);
  border-radius: var(--radius-lg);
  box-shadow: var(--pop-md);
}
.as-allsorts .as-cs-beforeafter__img img {
  border-radius: var(--radius-lg);
}

.as-allsorts .as-cs-beforeafter__img-placeholder {
  color: var(--grey-400);
}

.as-allsorts .as-cs-challenge__list li i {
  color: var(--grey-500);
}

.as-allsorts .as-cs-testimonial {
  background-color: var(--liquorice);
}
.as-allsorts .as-cs-testimonial__icon {
  color: var(--sunshine);
  opacity: 1;
}

.as-allsorts .as-cs-hero__link {
  color: var(--ink-900);
}

.as-allsorts .as-cs-hero__media {
  position: relative;
  display: flex;
  align-items: center;
}
.as-allsorts .as-cs-hero__media-desktop {
  position: relative;
  z-index: 1;
  width: 88%;
  aspect-ratio: 16 / 10;
  border: 0;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
  transform: rotate(-3deg);
}
.as-allsorts .as-cs-hero__media-phone {
  position: absolute;
  z-index: 2;
  right: -6%;
  bottom: 0;
  width: 34%;
  aspect-ratio: 9 / 17;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
  transform: rotate(5deg) translateY(28px);
}
.as-allsorts .as-cs-hero__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
}

.as-allsorts .as-cs-challenge__group-title {
  color: var(--ink-900);
}

.as-allsorts .as-cs-beforeafter__label--after {
  color: var(--ink-900);
}

@media (min-width: 481px) {
  .as-allsorts .as-cs-challenge,
  .as-allsorts .as-cs-beforeafter {
    padding-top: var(--as-pad-band);
    padding-bottom: var(--as-pad-band);
  }
}

@media (min-width: 481px) {
  .as-allsorts .as-cs-solution {
    padding: var(--as-pad-ink) var(--as-pad-side);
  }
}

@media (min-width: 481px) {
  .as-allsorts .as-cs-page-cta {
    padding-top: var(--as-pad-cta-top);
    padding-bottom: var(--as-clear-wave);
  }
}

.as-hero--about-footer{
  position:absolute;
  left:0; right:0; bottom:0;
  width:100%; height:102px;
  border-top:0;
  border-bottom:5px solid var(--liquorice);
  overflow:hidden;
  background:transparent;
}
.as-hero--about-footer .as-hero__img{
  width:100%; height:100%;
  object-fit:cover;
  object-position:50% 8%;
  clip-path:url(#wave-clip-about-footer);
  display:block;
}
.as-hero--about-footer .as-hero__stroke{
  position:absolute; inset:0;
  width:100%; height:100%;
  pointer-events:none;
  z-index:1;
}

